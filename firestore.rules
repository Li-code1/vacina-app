rules_version = '2';

// Regras de Segurança do Firestore — VacinaJá
//
// Princípio central: NENHUM dado de uma criança pode ser lido ou escrito
// por alguém que não seja o responsável (ownerId) que a cadastrou.
// Isso vale mesmo que a chamada não venha do app (ex: alguém usando a
// API do Firestore diretamente) — a regra é aplicada no servidor,
// não no cliente.
service cloud.firestore {
  match /databases/{database}/documents {

    // Coleção "children": cada documento tem um campo ownerId = uid do responsável.
    match /children/{childId} {
      allow read, update, delete: if isOwner(resource.data.ownerId);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;

      // Sub-coleção "doses": herda a permissão verificando o documento pai.
      match /doses/{doseId} {
        allow read, write: if isOwner(get(/databases/$(database)/documents/children/$(childId)).data.ownerId);
      }
    }

    // Coleção "campaigns": informativa, qualquer usuário autenticado pode ler;
    // escrita reservada para administração (feita via Console/Cloud Functions).
    match /campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }
  }
}
